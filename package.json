{
  "name": "mini-hot-hub",
  "version": "1.0.0",
  "description": "多平台热搜聚合网站",
  "scripts": {
    "dev:client": "cd client && npm run dev",
    "dev:server": "cd server && npm run dev",
    "dev": "concurrently \"npm run dev:client\" \"npm run dev:server\"",
    "build": "cd client && npm run build",
    "start": "cd server && npm start",
    "postinstall": "node -e \"if (process.env.VERCEL) process.exit(0); else require('child_process').execSync('cd client && npm install && cd ../server && npm install', {stdio: 'inherit'})\""
  },
  "keywords": ["hot", "trending", "聚合"],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
